# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_USER_ID=your_telegram_user_id_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WordPress
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=your_wordpress_application_password

# Google Search Console (Indexing API)
# 서비스 계정 JSON 키 파일 경로
GOOGLE_SERVICE_ACCOUNT_JSON=./google_service_account.json

# Bing Webmaster Tools
BING_API_KEY=your_bing_webmaster_api_key_here

