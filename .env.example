# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_USER_ID=your_telegram_user_id_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WordPress
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=your_wordpress_application_password

# Content / SEO guardrails
# 예: 여의도 재건축과 실거주 관점 부동산 정보를 직접 확인한 자료로 정리하는 블로그
SITE_FOCUS=독자가 직접 의사결정에 활용할 수 있는 한국어 정보형 블로그
WP_POST_STATUS=draft
WP_ALLOWED_CATEGORIES=Life Trend,IT Trend
WP_DEFAULT_CATEGORY=Life Trend
WP_MAX_TAGS=3
WP_CREATE_MISSING_TAGS=false
REFERENCE_MAX_URLS=3
REFERENCE_MAX_CHARS=3500

# Google Search Console (Indexing API)
# 서비스 계정 JSON 키 파일 경로
GOOGLE_SERVICE_ACCOUNT_JSON=./google_service_account.json
# 일반 블로그 글은 공식적으로 Google Indexing API 대상이 아닙니다.
GOOGLE_INDEXING_ENABLED=false

# Bing Webmaster Tools
BING_API_KEY=your_bing_webmaster_api_key_here

# Naver Search Advisor / IndexNow
# NAVER_INDEXNOW_KEY 값과 동일한 txt 파일을 사이트 루트에 업로드해야 합니다.
# 예: https://your-wordpress-site.com/{NAVER_INDEXNOW_KEY}.txt
NAVER_INDEXNOW_KEY=your_indexnow_key_here
# 루트가 아닌 다른 위치에 key 파일을 둘 때만 설정합니다.
NAVER_INDEXNOW_KEY_LOCATION=

# X.com auto post
# X 개발자 포털에서 Read and write 권한의 API key/access token을 발급한 뒤 true로 바꿉니다.
X_AUTO_POST=false
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
